# GITHUB_TOKEN: Optional. Required only to display the contribution calendar
# in the GitHub app. Create a classic PAT with `read:user` scope at:
# https://github.com/settings/tokens
GITHUB_TOKEN=""

# SPOTIFY: Optional. Required for the "Now Playing" desktop widget.
# Step 1 — Create an app at https://developer.spotify.com/dashboard
#           Add http://localhost:3000/callback as a Redirect URI
# Step 2 — Grab your Client ID and Client Secret from the dashboard
# Step 3 — Get a refresh token with the `user-read-currently-playing` scope.
#           Easiest way: https://accounts.spotify.com/authorize?client_id=YOUR_ID&response_type=code&redirect_uri=http://localhost:3000/callback&scope=user-read-currently-playing
#           Exchange the code for tokens via POST to https://accounts.spotify.com/api/token
#           (see Spotify docs: Authorization Code Flow)
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_REFRESH_TOKEN=""
